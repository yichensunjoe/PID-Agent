{
  "name": "pid-agent-frontend",
  "private": true,
  "version": "2.1.0-alpha.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:headed": "npm run build:e2e && playwright test --headed",
    "test:e2e:update": "npm run build:e2e && playwright test e2e/visual.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2"
  }
}
